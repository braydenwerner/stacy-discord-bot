# Copy to .env and fill in values. See README.md for details.

# --- Discord (required) ---
TOKEN=
CLIENT_ID=
GUILD_ID=

# --- OpenAI (required) ---
OPENAI_API_KEY=
OPENAI_ORG_ID=

# --- Optional ---
# DATABASE_PATH=./data/stacy.db
# STACY_OWNER_ID=
# TAVILY_API_KEY=
# CURSOR_API_KEY=
# GITHUB_TOKEN=
# YOUTUBE_COOKIE=
# DEBUG_ENABLED=true

# --- Minecraft on AWS (from `aws cloudformation describe-stacks --stack-name stacy-mc`) ---
AWS_REGION=us-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MINECRAFT_INSTANCE_ID=
MINECRAFT_SERVER_HOST=mc.motelrate.com
MINECRAFT_PORT=25565
MINECRAFT_BACKUP_BUCKET=
# Must match IdleShutdownMinutes on the EC2 host (default 30)
# MINECRAFT_IDLE_SHUTDOWN_MINUTES=30
# MINECRAFT_SSH_KEY_PATH=/home/breadone/server/stacy-discord-bot/minecraft/stacy-mc
# MINECRAFT_NOTIFY_CHANNEL_ID=1511949691858718771
# AWS_BUDGET_NAME=
# AWS_MONTHLY_BUDGET_USD=50
# AWS_PROMO_CREDIT_USD=
