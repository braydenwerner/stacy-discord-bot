# Copy to bot.env (gitignored). Values come from CloudFormation stack outputs after deploy,
# or run: pnpm run minecraft:fetch-env
#
# From the machine that ran deploy.sh:
#   aws cloudformation describe-stacks --stack-name stacy-mc --region us-west-1 \
#     --query 'Stacks[0].Outputs'

AWS_REGION=us-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MINECRAFT_INSTANCE_ID=i-071aa0fa973de554e
MINECRAFT_SERVER_HOST=mc.motelrate.com
MINECRAFT_PORT=25565
MINECRAFT_BACKUP_BUCKET=
# Must match IdleShutdownMinutes on the EC2 host (default 30)
MINECRAFT_IDLE_SHUTDOWN_MINUTES=30
# Optional billing display (requires ce:GetCostAndUsage on bot IAM user)
# AWS_BUDGET_NAME=
# AWS_MONTHLY_BUDGET_USD=50
# AWS_PROMO_CREDIT_USD=
# AWS_ACCOUNT_ID=
# MINECRAFT_SSH_KEY_PATH=/home/breadone/server/stacy-discord-bot/minecraft/stacy-mc
# MINECRAFT_NOTIFY_CHANNEL_ID=1511949691858718771
