    "mediaplex": "1.0.0",
    "prettier": "^3.8.3",
    "zod": "^4.4.3"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
