    "@discordjs/builders": "^1.14.1",
    "@discordjs/voice": "^0.19.2",
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^1.4.7",
    "@octokit/rest": "^22.0.1",
    "@web-scrobbler/metadata-filter": "^3.2.0",
    "discord-player": "^7.2.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "duck-duck-scrape": "^2.2.7",
